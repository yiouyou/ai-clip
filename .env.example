# Copy to .env and fill in. Only what you actually use is required.
# Provider-specific keys are auto-detected from the LLM base_url; you usually
# only need the one matching your configured llm.base_url.

# LLM for analyze + storyboard (OpenAI-compatible). Default base_url is DeepSeek.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# OpenAI-compatible review endpoint base, including /v1.
NEWAPP_URL=
NEWAPP_API_KEY=
TAVILY_API_KEY=

# Optional explicit overrides (take precedence over the auto-detected key above).
# base_url is the FULL base incl. /v1.
# DeepSeek (default): https://api.deepseek.com/v1 + deepseek-v4-pro
# OpenAI: AICLIP_LLM_BASE_URL=https://api.openai.com/v1  +  AICLIP_LLM_MODEL=gpt-5.5
# AICLIP_LLM_BASE_URL=https://api.deepseek.com/v1
# AICLIP_LLM_MODEL=deepseek-v4-pro
# AICLIP_LLM_API_KEY=

# Xiaomi MiMo TTS / voice cloning (https://mimo.mi.com).
MIMO_API_KEY=

# ComfyUI HTTP endpoint (API mode for local image generation).
AICLIP_COMFYUI_URL=http://127.0.0.1:8188

# Optional Smart Illustrator image provider.
# Set assets.image_provider=smart_illustrator in config to use it.
AICLIP_SMART_ILLUSTRATOR_DIR=
AICLIP_SMART_ILLUSTRATOR_SCRIPT=
# AICLIP_SMART_ILLUSTRATOR_PROVIDER=gemini
# AICLIP_SMART_ILLUSTRATOR_MODEL=gemini-3-pro-image-preview

# Optional radar channel list override.
# AICLIP_RADAR_CHANNELS=config/channels.yaml
# AICLIP_RADAR_FEEDBACK=config/radar-feedback.yaml
# Daily collect/run skips a stuck channel after this many seconds; 0 disables.
# AICLIP_RADAR_CHANNEL_TIMEOUT_SEC=60
# Parallel channel collectors when timeout is enabled.
# AICLIP_RADAR_CHANNEL_WORKERS=4
# Set to 0/false to skip faster-whisper fallback when a Top 3 video has no subtitles.
# AICLIP_RADAR_TRANSCRIBE_MISSING=true
# Radar fallback defaults to small for speed; main extract/remix can still use medium.
# AICLIP_RADAR_TRANSCRIBE_MODEL_SIZE=small

# Optional source-research controls. Max searches are clamped to 1-3 per run.
# AICLIP_SOURCE_RESEARCH_MAX_SEARCHES=2
# AICLIP_SOURCE_RESEARCH_MAX_RESULTS=5
