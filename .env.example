# Copy to .env and fill in. Only what you actually use is required.
# Provider-specific keys are auto-detected from the LLM base_url; you usually
# only need the one matching your configured llm.base_url.

# LLM for analyze + storyboard (OpenAI-compatible). Default base_url is DeepSeek.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional explicit overrides (take precedence over the auto-detected key above).
# DeepSeek (default): model deepseek-v4-pro
# OpenAI: AICLIP_LLM_BASE_URL=https://api.openai.com/v1  +  AICLIP_LLM_MODEL=gpt-5.5
# AICLIP_LLM_BASE_URL=https://api.deepseek.com
# AICLIP_LLM_MODEL=deepseek-v4-pro
# AICLIP_LLM_API_KEY=

# Xiaomi MiMo TTS / voice cloning (https://mimo.mi.com).
MIMO_API_KEY=

# ComfyUI HTTP endpoint (API mode for local image generation).
AICLIP_COMFYUI_URL=http://127.0.0.1:8188
