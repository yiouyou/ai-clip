# Copy to .env and fill in. Only what you actually use is required.

# LLM for analyze + storyboard prompt generation (OpenAI-compatible endpoint).
# Works with DeepSeek / Qwen / Moonshot / OpenAI etc.
AICLIP_LLM_BASE_URL=https://api.deepseek.com
AICLIP_LLM_API_KEY=
AICLIP_LLM_MODEL=deepseek-chat

# Optional: Google key, only if you enable the (off-by-default) Gemini/Imagen/Veo providers.
GOOGLE_API_KEY=

# ComfyUI HTTP endpoint (API mode for local image/video generation).
AICLIP_COMFYUI_URL=http://127.0.0.1:8188
